# ── SPIDER Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Ollama (Primary) ───────────────────────────────────────────────────
# SPIDER uses Qwen3.5 Abliterated locally via Ollama.
# Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# Pull models:    ollama pull huihui_ai/qwen3.5-abliterated:9b
#                 ollama pull huihui_ai/qwen3.5-abliterated:4b
SPIDER_OLLAMA_BASE_URL=http://localhost:11434
SPIDER_PRIMARY_MODEL=huihui_ai/qwen3.5-abliterated:9b
SPIDER_EVAL_MODEL=huihui_ai/qwen3.5-abliterated:4b

# ── Cloud Fallback (Optional) ──────────────────────────────────────────
SPIDER_OPENROUTER_API_KEY=
SPIDER_FALLBACK_MODEL=anthropic/claude-sonnet-4-5-20250929

# ── Safety ─────────────────────────────────────────────────────────────
SPIDER_ALLOWED_TARGETS=
SPIDER_EXCLUDED_TARGETS=0.0.0.0,127.0.0.1,localhost
SPIDER_RULES_OF_ENGAGEMENT=No destructive actions without human approval. No production targets without explicit written authorization.

# ── Lab ────────────────────────────────────────────────────────────────
SPIDER_LAB_NETWORK=172.20.0.0/24

# ── Intelligence APIs (Optional) ───────────────────────────────────────
SPIDER_NVD_API_KEY=
SPIDER_SHODAN_API_KEY=
SPIDER_VIRUSTOTAL_API_KEY=

# ── Observability (Optional) ───────────────────────────────────────────
SPIDER_LANGFUSE_PUBLIC_KEY=
SPIDER_LANGFUSE_SECRET_KEY=
SPIDER_LANGFUSE_HOST=https://cloud.langfuse.com
